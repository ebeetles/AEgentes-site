---
const year = new Date().getFullYear();
---

<footer class="foot on-pine">
  <div class="wrap">
    <div class="foot-cta">
      <p class="tag foot-kicker">Say hello</p>
      <h2 class="display foot-line">Let's put your <em>name</em> up.</h2>
      <a class="foot-mail" href="mailto:hello@aegentes.com">hello@aegentes.com</a>
    </div>

    <div class="foot-grid">
      <div class="open-sign" aria-label="Studio status: open, taking on new projects">
        <span class="livedot" aria-hidden="true"></span>
        <span class="open-word">OPEN</span>
        <span class="open-note tag">Taking on<br />new projects</span>
      </div>

      <nav class="foot-nav" aria-label="Footer">
        <p class="tag foot-h">Around the shop</p>
        <a href="/work/">Work</a>
        <a href="/studio/">Studio</a>
        <a href="/contact/">Contact</a>
      </nav>

      <div class="foot-hours">
        <p class="tag foot-h">Shop hours</p>
        <p class="hours-line">Your time: <span class="mono" data-clock>—:—</span></p>
        <p class="hours-note">Write any hour. We reply within one working day, usually sooner.</p>
      </div>
    </div>

    <div class="colophon">
      <p>© {year} Ægentes · aegentes.com</p>
      <p class="colo-latin"><em>Ægentes</em> — from the Latin <em>agentes</em>: the ones who do.</p>
      <p>Set in Besley, Work Sans &amp; Spline Sans Mono. Built by hand.</p>
    </div>
  </div>
</footer>

<style>
  .foot { padding-block: clamp(4rem, 8vw, 7rem) 2rem; }

  .foot-cta { display: grid; gap: 1.3rem; justify-items: start; }
  .foot-kicker { color: var(--brass-2); }
  .foot-line { max-width: 9em; }
  .foot-line em { color: var(--brass-2); }
  .foot-mail {
    font-family: var(--f-display);
    font-style: italic;
    font-size: clamp(1.4rem, 3.4vw, 2.6rem);
    font-weight: 480;
    font-variation-settings: 'wght' 480;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--brass-2);
    text-underline-offset: 0.18em;
    transition: color 0.25s var(--ease-out);
  }
  .foot-mail:hover { color: var(--brass-2); }

  .foot-grid {
    display: grid;
    grid-template-columns: auto 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
    margin-block: clamp(3rem, 6vw, 5rem) 3rem;
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1.5px solid var(--hair-brass);
  }

  .open-sign {
    display: grid;
    justify-items: center;
    gap: 0.5rem;
    padding: 1.5rem 1.9rem 1.3rem;
    border: 2px solid var(--brass-2);
    border-radius: 10px;
    text-align: center;
    background: color-mix(in srgb, var(--bottle) 55%, transparent);
    box-shadow: inset 0 0 0 5px var(--pine), inset 0 0 0 6.5px var(--hair-brass);
  }
  .open-word {
    font-family: var(--f-display);
    font-weight: 750;
    font-variation-settings: 'wght' 750;
    font-size: 2rem;
    letter-spacing: 0.22em;
    margin-right: -0.22em;
    color: var(--brass-2);
    line-height: 1;
  }
  .open-note { opacity: 0.75; line-height: 1.5; }

  .foot-h { color: var(--brass-2); margin-bottom: 1rem; }
  .foot-nav { display: grid; gap: 0.45em; justify-items: start; }
  .foot-nav a {
    font-family: var(--f-display);
    font-size: 1.25rem;
    font-weight: 560;
    font-variation-settings: 'wght' 560;
    text-decoration: none;
  }
  .foot-nav a:hover { color: var(--brass-2); }

  .hours-line { font-size: 1.05rem; margin-bottom: 0.4rem; }
  .hours-line .mono { font-family: var(--f-mono); color: var(--brass-2); }
  .hours-note { opacity: 0.75; max-width: 26em; font-size: 0.95rem; }

  .colophon {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2.5rem;
    justify-content: space-between;
    border-top: 1.5px solid var(--hair-brass);
    padding-top: 1.4rem;
    font-size: 0.82rem;
    opacity: 0.72;
  }
  .colo-latin em { font-family: var(--f-display); }

  @media (max-width: 760px) {
    .foot-grid { grid-template-columns: 1fr; }
    .open-sign { justify-self: start; }
  }
</style>
