---
/**
 * A shopfront: fascia board with the client's name in gold,
 * the work in the window, the details on the sill.
 */
import Cover from './Cover.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'>;
  headingLevel?: 'h2' | 'h3';
}
const { entry, headingLevel: H = 'h3' } = Astro.props;
const { client, trade, place, year, summary, palette, motif, cover } = entry.data;
---

<a class="shopfront" href={`/work/${entry.id}/`}>
  <span class="fascia">
    <H class="fascia-name">{client}</H>
    <span class="fascia-year mono">’{String(year).slice(2)}</span>
  </span>
  <span class="window">
    <Cover id={entry.id} {client} {trade} {year} {palette} {motif} {cover} />
    <span class="shine" aria-hidden="true"></span>
  </span>
  <span class="sill">
    <span class="sill-meta">
      <span class="tag sill-trade">{trade} · {place}</span>
      <span class="sill-summary">{summary}</span>
    </span>
    <span class="tag sill-visit">Step inside <span class="arrow">→</span></span>
  </span>
</a>

<style>
  .shopfront {
    display: flex;
    flex-direction: column;
    border: 2px solid var(--ink);
    border-radius: var(--frame-r);
    overflow: hidden;
    background: var(--paper);
    text-decoration: none;
    transition: transform 0.35s var(--ease-out), box-shadow 0.35s var(--ease-out);
  }
  .shopfront:hover { transform: translateY(-5px); box-shadow: var(--shadow-lift); }

  .fascia {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.15rem 0.8rem;
    background: var(--pine);
    border-bottom: 2px solid var(--ink);
  }
  .fascia-name {
    font-family: var(--f-display);
    font-size: clamp(1.15rem, 1rem + 0.8vw, 1.5rem);
    font-weight: 640;
    font-variation-settings: 'wght' 640;
    line-height: 1.1;
    letter-spacing: 0.015em;
    color: var(--brass-2);
    margin: 0;
  }
  .fascia-year { font-size: 0.8rem; color: var(--plaster); opacity: 0.65; }

  .window {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-bottom: 2px solid var(--ink);
  }
  .window :global(.coverart) {
    height: 100%;
    transition: transform 0.6s var(--ease-out);
  }
  .shopfront:hover .window :global(.coverart) { transform: scale(1.035); }

  /* light sweeping across the glass */
  .shine {
    position: absolute;
    inset: -30%;
    background: linear-gradient(105deg, transparent 42%, rgba(255, 255, 250, 0.16) 50%, transparent 58%);
    transform: translateX(-85%);
    pointer-events: none;
  }
  .shopfront:hover .shine { transition: transform 0.8s var(--ease-out); transform: translateX(85%); }

  .sill {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.2rem;
    padding: 1.05rem 1.15rem 1.1rem;
    color: var(--ink);
    flex: 1;
  }
  .sill-meta { display: grid; gap: 0.5rem; }
  .sill-trade { color: var(--brass); }
  .sill-summary {
    font-size: 0.95rem;
    line-height: 1.5;
    max-width: 34em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sill-visit { white-space: nowrap; }
  .sill-visit .arrow { display: inline-block; transition: transform 0.25s var(--ease-out); }
  .shopfront:hover .sill-visit .arrow { transform: translateX(4px); }

  @media (max-width: 560px) {
    .sill { flex-direction: column; align-items: flex-start; gap: 0.9rem; }
    .sill-trade { letter-spacing: 0.12em; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shine { display: none; }
  }
</style>
