---
import '@fontsource-variable/besley';
import '@fontsource-variable/besley/wght-italic.css';
import '@fontsource-variable/work-sans';
import '@fontsource-variable/spline-sans-mono';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** colour of the content the fixed nav initially sits on */
  theme?: 'pine' | 'plaster';
  ogImage?: string;
}

const {
  title,
  description,
  theme = 'plaster',
  ogImage = '/og.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogUrl = new URL(ogImage, Astro.site);

// Organization schema — helps Google's Knowledge Graph and AI answer
// engines (ChatGPT, Perplexity, AI Overviews) resolve "Ægentes" as a
// real business rather than an ambiguous word.
// Add real profile URLs to `sameAs` as they're created — each one is
// also a corroborating signal for the entity.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Ægentes',
  url: 'https://www.aegentes.com/',
  logo: new URL('/favicon.svg', Astro.site).toString(),
  image: ogUrl.toString(),
  description: 'Ægentes builds websites and AI receptionists for shops, trades and independents — a shopfront that looks like your trade, and a voice that answers the phone when you can\'t.',
  email: 'alan@aegentes.com',
  telephone: '+1-650-668-4007',
  areaServed: 'US',
  sameAs: [],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#1c3a2e" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ægentes" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <ClientRouter />
  </head>
  <body data-theme={theme}>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav theme={theme} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script src="../scripts/main.ts"></script>
  </body>
</html>
