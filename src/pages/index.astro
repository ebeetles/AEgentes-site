---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import FlapBoard from '../components/FlapBoard.astro';
import WorkCard from '../components/WorkCard.astro';
import Receipt from '../components/Receipt.astro';
import heroStreet from '../assets/hero-street.png';
import heroLights from '../assets/hero-lights.png';
import spotSign from '../assets/spot-sign.png';
import spotPhone from '../assets/spot-phone.png';
import vacantShop from '../assets/vacant-shop.png';

const work = (await getCollection('work'))
  .sort((a, b) => a.data.order - b.data.order)
  .filter((w) => w.data.featured)
  .slice(0, 3);

const trades = [
  'bakers', 'barbers', 'florists', 'builders', 'dentists', 'roofers',
  'brewers', 'tailors', 'grocers', 'welders', 'framers', 'movers',
];

const steps = [
  {
    n: 'I', name: 'The chat', when: 'Day 1',
    copy: 'Thirty minutes, no jargon, no slide deck. We learn how your shop actually runs, what you sell most, and what a good month looks like.',
  },
  {
    n: 'II', name: 'The blueprint', when: 'Day 1',
    copy: 'One page that pins the whole plan down — sitemap, words, look, price. You approve it before we build a thing.',
  },
  {
    n: 'III', name: 'The build', when: 'Days 2–3',
    copy: 'Design and code, growing at a link you can open on your phone whenever you like. Two proper rounds of changes included.',
  },
  {
    n: 'IV', name: 'The keys', when: 'Day 4',
    copy: 'We launch, point your domain, sort your email, and teach you to run it all in an hour. Then it’s yours — files, accounts, everything.',
  },
];
---

<Base
  title="Ægentes — websites & AI receptionists for small business"
  description="Ægentes builds the whole shopfront for small business: a website that looks like your trade, and an AI receptionist that answers the phone when you can't."
  theme="pine"
>
  <!-- ============ hero ============ -->
  <section class="hero on-pine" data-hero>
    <!-- backdrop: etched street at dusk, lamplight, stage glow -->
    <div class="hero-scene" aria-hidden="true">
      <div class="hero-spot"></div>
      <div class="hero-lights" data-hero-lights>
        <div class="hero-lights-fig">
          <Image
            class="hero-lights-img"
            src={heroLights}
            widths={[880, 1400, 1750, 3168]}
            sizes="min(100vw, 1750px)"
            format="webp"
            quality={82}
            alt=""
            loading="eager"
          />
          <span class="bulb" style="--bx: 55%; --by: 20.6%; --tw: 4.8s; --td: 0s"></span>
          <span class="bulb" style="--bx: 64.3%; --by: 36%; --tw: 6.2s; --td: 1.4s"></span>
          <span class="bulb" style="--bx: 74.5%; --by: 45.4%; --tw: 5.4s; --td: 0.7s"></span>
          <span class="bulb" style="--bx: 89.5%; --by: 37.1%; --tw: 7.1s; --td: 2.1s"></span>
        </div>
      </div>
      <div class="hero-street" data-hero-street>
        <div class="hero-street-fig">
          <div class="hero-lamplight"></div>
          <Image
            class="hero-street-img"
            src={heroStreet}
            widths={[880, 1400, 1750, 3168]}
            sizes="(max-width: 760px) 200vw, min(100vw, 1750px)"
            format="webp"
            quality={82}
            alt=""
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
      <div class="hero-scrim"></div>
    </div>

    <div class="wrap hero-grid" data-hero-copy>
      <div class="hero-in">
        <p class="plaque plaque--brass" data-reveal>Ægentes · Websites & AI reception · Est. 2026</p>

        <h1 class="display lines hero-h1">
          <span class="l"><span class="li" style="--d: 90ms">We put small business</span></span>
          <span class="l"><span class="li" style="--d: 200ms">up <em>in lights.</em></span></span>
        </h1>

        <div class="hero-flap" data-reveal style="--d: 380ms">
          <FlapBoard label="Now serving" words={trades} />
        </div>

        <p class="lede hero-lede" data-reveal style="--d: 500ms">
          We build the whole shopfront for shops, trades and independents — a website that
          looks like your work, and an AI receptionist that answers the phone when you can't.
          Proper, fast, and unmistakably yours.
        </p>

        <div class="hero-ctas" data-reveal style="--d: 600ms">
          <a class="btn btn--plaster" href="/contact/">Start a project <span class="arrow">→</span></a>
          <a class="btn btn--ghost-pine" href="/work/">See the work</a>
        </div>
      </div>
    </div>

    <div class="wrap hero-foot" data-reveal style="--d: 750ms">
      <p class="hero-latin"><em>Ægentes</em> — from the Latin <em>agentes</em>: the ones who do.</p>
      <a class="tag hero-cue" href="#what-we-do">Walk the street <span class="cue-arrow">↓</span></a>
      <p class="tag hero-open">Open — booking new projects</p>
    </div>
  </section>

  <!-- ============ what we do ============ -->
  <section class="band do-band" id="what-we-do">
    <div class="wrap">
      <header class="sect-head">
        <p class="plaque plaque--brass" data-reveal>What we do</p>
        <h2 class="display" data-reveal style="--d: 100ms">Two ways to <em>show up.</em></h2>
      </header>

      <div class="do-grid">
        <article class="do-card" data-reveal>
          <Image class="do-etch" src={spotSign} widths={[320, 640]} sizes="6.5rem" format="webp" alt="" loading="lazy" />
          <p class="tag do-tag">01 · Websites</p>
          <h3 class="display do-line">A shopfront that looks like your trade.</h3>
          <p class="do-copy">
            Designed and built by hand, drawn from the business itself — its colours, its
            counter, its customers. Proper, fast, and unmistakably yours. Done in days, not weeks.
          </p>
          <a class="do-link tag" href="/work/">See the work <span class="arrow">→</span></a>
        </article>

        <article class="do-card do-card--brass" data-reveal style="--d: 120ms">
          <Image class="do-etch" src={spotPhone} widths={[320, 640]} sizes="6.5rem" format="webp" alt="" loading="lazy" />
          <p class="tag do-tag">02 · AI receptionist <span class="do-new">New</span></p>
          <h3 class="display do-line">A voice that answers every call.</h3>
          <p class="do-copy">
            Miss a call, miss a job. Ours picks up on the first ring — day or night — answers
            the regulars, books the appointment, and texts you the details. It sounds like your
            shop, not a call centre.
          </p>
          <a class="do-link tag" href="/contact/">Hear it answer <span class="arrow">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ recent work ============ -->
  <section class="band work-band">
    <div class="wrap">
      <header class="sect-head sect-head--split">
        <div>
          <p class="plaque plaque--brass" data-reveal>The work</p>
          <h2 class="display" data-reveal style="--d: 100ms">Recent shopfronts.</h2>
        </div>
        <a class="tag head-link" href="/work/" data-reveal style="--d: 200ms">All work <span class="arrow">→</span></a>
      </header>

      <div class="work-grid">
        {work.map((entry, i) => (
          <div data-reveal style={`--d: ${i * 120}ms`}>
            <WorkCard entry={entry} headingLevel="h3" />
          </div>
        ))}
        <a class="vacant" href="/contact/" data-reveal style="--d: 360ms">
          <Image class="vacant-etch" src={vacantShop} widths={[480, 800]} sizes="24rem" format="webp" alt="" loading="lazy" />
          <span class="tag vacant-tag">Vacant · apply within</span>
          <span class="display vacant-line">Your name here.</span>
          <span class="tag vacant-cta">Start a project <span class="arrow">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ the receipt ============ -->
  <section class="band ticket-band">
    <div class="wrap ticket-grid">
      <div class="ticket-copy">
        <p class="plaque plaque--brass" data-reveal>What you get</p>
        <h2 class="display" data-reveal style="--d: 100ms">Everything on <em>the ticket.</em></h2>
        <p class="lede" data-reveal style="--d: 200ms">
          One flat scope, agreed up front, itemised like it matters. No mystery line
          items, no "that'll be extra" halfway through. If it's on the receipt, it ships.
        </p>
        <p class="ticket-note" data-reveal style="--d: 300ms">
          Most projects are done in a few days, door to door. If yours needs more — bookings,
          ordering, a shop — we'll say so on day one, with a number attached.
        </p>
      </div>
      <div class="ticket-paper" data-reveal style="--d: 250ms">
        <Receipt />
      </div>
    </div>
  </section>

  <!-- ============ process ============ -->
  <section class="band on-pine process-band scalloped" style="--scallop-above: color-mix(in srgb, var(--brass) 10%, var(--plaster))">
    <div class="wrap">
      <header class="sect-head">
        <p class="plaque plaque--brass" data-reveal>How it goes</p>
        <h2 class="display" data-reveal style="--d: 100ms">A few days, <em>four steps.</em></h2>
      </header>

      <ol class="steps">
        {steps.map((s, i) => (
          <li class="step" data-reveal style={`--d: ${i * 90}ms`}>
            <span class="step-n mono" aria-hidden="true">{s.n}</span>
            <div class="step-body">
              <h3 class="display step-name">{s.name}</h3>
              <p class="step-copy">{s.copy}</p>
            </div>
            <span class="tag step-when">{s.when}</span>
          </li>
        ))}
      </ol>

      <p class="steps-after" data-reveal>
        And then we stick around — small tweaks, seasonal updates, and a real
        person on the other end of <a href="mailto:alan@aegentes.com">alan@aegentes.com</a>.
      </p>
    </div>
  </section>

  <!-- ============ who it's for ============ -->
  <section class="band fit-band">
    <div class="wrap">
      <p class="plaque plaque--brass" data-reveal>Who it's for</p>
      <h2 class="display fit-line lines">
        <span class="l"><span class="li">Made for the corner shop,</span></span>
        <span class="l"><span class="li" style="--d: 110ms">the two-truck crew,</span></span>
        <span class="l"><span class="li" style="--d: 220ms"><em>the chair by appointment.</em></span></span>
      </h2>
      <div class="fit-cols">
        <p class="fit-copy" data-reveal>
          We don't chase brands with brand teams. We work with people whose name is
          over the door — where the website isn't a marketing asset, it's the front
          of the shop. That's a responsibility we take personally.
        </p>
        <a class="btn btn--ghost-ink fit-btn" data-reveal style="--d: 120ms" href="/studio/">Meet the studio <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---- hero ---- */
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100svh;
    padding-top: clamp(6rem, 12vh, 8.5rem);
    overflow: clip;
  }

  /* the etched street scene — all decorative, all behind the copy */
  .hero-scene { position: absolute; inset: 0; pointer-events: none; }

  /* stage light behind the headline — "up in lights" */
  .hero-spot {
    position: absolute;
    top: 4%;
    left: -14%;
    width: min(58rem, 88vw);
    aspect-ratio: 1;
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--brass-2) 14%, transparent),
      color-mix(in srgb, var(--brass-2) 5%, transparent) 48%,
      transparent 72%
    );
    animation: spot-breathe 9s ease-in-out infinite alternate;
  }
  @keyframes spot-breathe {
    from { transform: scale(1); opacity: 0.8; }
    to   { transform: scale(1.07); opacity: 1; }
  }

  /* festoon lights strung across the sky — strongest upper-right,
     ghosted where they pass behind the headline */
  .hero-lights { position: absolute; inset: 0; will-change: transform; }
  .hero-lights-fig {
    position: absolute;
    top: 0;
    left: 50%;
    translate: -50% 0;
    width: min(100%, 1750px);
  }
  .hero-lights-img {
    width: 100%;
    height: auto;
    opacity: 0.5;
    -webkit-mask-image:
      linear-gradient(90deg, transparent 3%, #000 36%),
      linear-gradient(180deg, #000 52%, transparent 94%);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(90deg, transparent 3%, #000 36%),
      linear-gradient(180deg, #000 52%, transparent 94%);
    mask-composite: intersect;
  }
  .bulb {
    position: absolute;
    left: var(--bx);
    top: var(--by);
    width: 4.5%;
    aspect-ratio: 1;
    translate: -50% -50%;
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, #f4e0a4 32%, transparent),
      color-mix(in srgb, var(--brass-2) 12%, transparent) 45%,
      transparent 72%
    );
    animation: bulb-twinkle var(--tw, 5s) ease-in-out var(--td, 0s) infinite alternate;
  }
  @keyframes bulb-twinkle {
    from { opacity: 0.35; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1.06); }
  }

  .hero-street { position: absolute; inset: 0; will-change: transform; }
  .hero-street-fig {
    position: absolute;
    bottom: -2px;
    left: 50%;
    translate: -50% 0;
    width: min(100%, 1750px);
  }
  .hero-street-img {
    width: 100%;
    height: auto;
    /* the artwork's ground is near-identical to --pine; low opacity plus
       faded edges make the remaining difference invisible (no blend mode —
       mix-blend-mode + transforms flickers in some compositors) */
    opacity: 0.78;
    -webkit-mask-image:
      linear-gradient(180deg, transparent 6%, #000 42%),
      linear-gradient(90deg, transparent, #000 4% 96%, transparent);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(180deg, transparent 6%, #000 42%),
      linear-gradient(90deg, transparent, #000 4% 96%, transparent);
    mask-composite: intersect;
  }
  /* the etched lamp actually glows at dusk */
  .hero-lamplight {
    position: absolute;
    left: 61%;
    bottom: 44%;
    width: 30%;
    aspect-ratio: 1;
    translate: -50% 50%;
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--brass-2) 26%, transparent),
      color-mix(in srgb, var(--brass-2) 9%, transparent) 40%,
      transparent 70%
    );
    animation: lamp-breathe 6.5s ease-in-out infinite alternate;
  }
  @keyframes lamp-breathe {
    from { opacity: 0.65; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1.05); }
  }

  /* keeps copy legible where it overlaps the etching */
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg,
        color-mix(in srgb, var(--pine) 68%, transparent) 0%,
        color-mix(in srgb, var(--pine) 38%, transparent) 36%,
        transparent 62%),
      linear-gradient(180deg, transparent 74%,
        color-mix(in srgb, var(--pine) 56%, transparent) 100%);
  }

  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
    will-change: transform, opacity;
  }
  .hero-in { display: grid; gap: 1.55rem; justify-items: start; max-width: 52rem; }
  .hero-h1 { max-width: 11em; }
  .hero-h1 em { color: var(--brass-2); }
  /* gold-foil shimmer across "in lights." — decorative, degrades to brass */
  @supports (-webkit-background-clip: text) or (background-clip: text) {
    .hero-h1 em {
      color: transparent;
      background: linear-gradient(
        105deg,
        #a17a2c 0%,
        var(--brass-2) 32%,
        #f4e0a4 50%,
        var(--brass-2) 68%,
        #a17a2c 100%
      );
      background-size: 240% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      animation: foil-sweep 7s ease-in-out infinite;
    }
  }
  @keyframes foil-sweep {
    0%, 100% { background-position: 8% 0; }
    50%      { background-position: 92% 0; }
  }
  .hero-flap { margin-block: 0.35rem; }
  .hero-lede { opacity: 0.92; max-width: 40em; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 0.3rem; }

  .hero-foot {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 2.5rem;
    justify-content: space-between;
    align-items: center;
    border-top: 1.5px solid var(--hair-brass);
    padding-block: 1.15rem 1.3rem;
    margin-top: 3.5rem;
  }
  .hero-latin { font-size: 0.92rem; opacity: 0.8; }
  .hero-latin em { font-family: var(--f-display); }
  .hero-open { color: var(--brass-2); display: inline-flex; align-items: center; gap: 0.6em; }

  .hero-cue {
    color: var(--brass-2);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.7em;
    opacity: 0.85;
    transition: opacity 0.25s var(--ease-out);
  }
  .hero-cue:hover { opacity: 1; }
  .cue-arrow { display: inline-block; animation: cue-dip 2.6s var(--ease-out) infinite; }
  @keyframes cue-dip {
    0%, 100% { transform: translateY(-1px); }
    55%      { transform: translateY(3px); }
  }
  @media (max-width: 900px) {
    .hero-cue { display: none; }
  }
  @media (max-width: 760px) {
    .hero-street-fig { width: 200%; }
    .hero-street-img { opacity: 0.6; }
    .hero-lights-fig { width: 150%; left: auto; right: -22%; translate: 0 0; }
    .hero-lights-img { opacity: 0.38; }
    .hero-scrim {
      background:
        linear-gradient(180deg, transparent 62%,
          color-mix(in srgb, var(--pine) 62%, transparent) 100%);
    }
  }

  /* ---- what we do ---- */
  .do-band .sect-head { margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  .do-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 3.5vw, 3rem);
  }
  .do-card {
    position: relative;
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: clamp(1.8rem, 3vw, 2.6rem);
    border: 2px solid var(--ink);
    border-radius: var(--frame-r);
    background: var(--plaster);
  }
  .do-etch {
    position: absolute;
    top: clamp(1.1rem, 2vw, 1.6rem);
    right: clamp(1.1rem, 2vw, 1.6rem);
    width: clamp(4.2rem, 7vw, 6.5rem);
    height: auto;
    opacity: 0.95;
    pointer-events: none;
  }
  .do-card--brass {
    border-color: var(--pine);
    background: color-mix(in srgb, var(--brass) 12%, var(--plaster));
  }
  .do-tag {
    color: var(--brass);
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
  }
  .do-new {
    font-family: var(--f-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--plaster);
    background: var(--pine);
    padding: 0.25em 0.6em;
    border-radius: 999px;
  }
  .do-line { margin: 0; font-size: clamp(1.4rem, 1.1rem + 1.4vw, 2rem); max-width: 14em; padding-right: clamp(2.5rem, 5vw, 4.5rem); }
  .do-copy { opacity: 0.88; max-width: 34em; }
  .do-link {
    justify-self: start;
    margin-top: 0.4rem;
    text-decoration: none;
    border-bottom: 2px solid var(--brass);
    padding-bottom: 0.4em;
  }
  .do-link .arrow { display: inline-block; transition: transform 0.25s var(--ease-out); }
  .do-link:hover .arrow { transform: translateX(4px); }

  @media (max-width: 760px) {
    .do-grid { grid-template-columns: 1fr; }
  }

  /* ---- shared section header split ---- */
  .sect-head--split {
    grid-template-columns: 1fr auto;
    align-items: end;
  }
  .sect-head--split > div { display: grid; gap: 1.4rem; }
  .head-link {
    text-decoration: none;
    border-bottom: 2px solid var(--brass);
    padding-bottom: 0.45em;
  }
  .head-link .arrow { display: inline-block; transition: transform 0.25s var(--ease-out); }
  .head-link:hover .arrow { transform: translateX(4px); }

  /* ---- work grid ---- */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 3.2vw, 3rem);
  }
  .work-grid > :nth-child(even) { margin-top: clamp(0rem, 5vw, 4.5rem); }
  .work-grid > :nth-child(odd):not(:first-child) { margin-top: clamp(0rem, -2vw, -1.5rem); }

  .vacant {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    text-align: center;
    min-height: 24rem;
    border: 2.5px dashed color-mix(in srgb, var(--ink) 45%, transparent);
    border-radius: var(--frame-r);
    text-decoration: none;
    padding: 2rem;
    transition: background-color 0.3s var(--ease-out), border-color 0.3s var(--ease-out), color 0.3s var(--ease-out);
  }
  .vacant > * { position: relative; z-index: 1; }
  .vacant .vacant-etch {
    position: absolute;
    z-index: 0;
    left: 50%;
    bottom: -3%;
    height: 94%;
    width: auto;
    translate: -50% 0;
    opacity: 0.45;
    pointer-events: none;
    transition: opacity 0.3s var(--ease-out);
  }
  .vacant:hover .vacant-etch { opacity: 0.05; }
  .vacant-tag { color: var(--brass); }
  .vacant-line { font-size: var(--t-h3); }
  .vacant-cta { border-bottom: 2px solid var(--brass); padding-bottom: 0.4em; }
  .vacant:hover { background: var(--pine); border-color: var(--pine); color: var(--plaster); }
  .vacant:hover .vacant-tag { color: var(--brass-2); }
  .vacant .arrow { display: inline-block; transition: transform 0.25s var(--ease-out); }
  .vacant:hover .arrow { transform: translateX(4px); }

  /* ---- receipt band ---- */
  .ticket-band { background: color-mix(in srgb, var(--brass) 10%, var(--plaster)); }
  .ticket-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }
  .ticket-copy { display: grid; gap: 1.5rem; justify-items: start; }
  .ticket-note { max-width: 36em; opacity: 0.85; }
  .ticket-paper { justify-self: center; }

  /* ---- process ---- */
  .steps {
    list-style: none;
    padding: 0;
    display: grid;
  }
  .step {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    gap: 1.2rem 2rem;
