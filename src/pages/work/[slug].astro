---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Cover from '../../components/Cover.astro';

export async function getStaticPaths() {
  const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
  return work.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, next: work[(i + 1) % work.length] },
  }));
}

const { entry, next } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const swatches = [
  { hex: d.palette.bg, role: 'Ground' },
  { hex: d.palette.fg, role: 'Lettering' },
  { hex: d.palette.accent, role: 'Trim' },
];
---

<Base
  title={`${d.client} — Ægentes`}
  description={d.summary}
  theme="pine"
>
  <!-- ============ case head ============ -->
  <section class="case-head on-pine">
    <div class="wrap">
      <p class="tag crumb" data-reveal>
        <a href="/work/">Work</a> <span aria-hidden="true">/</span> {d.trade}
      </p>
      <h1 class="display lines case-title">
        <span class="l"><span class="li" style="--d: 80ms">{d.client}</span></span>
      </h1>
      <p class="lede case-lede" data-reveal style="--d: 220ms">{d.summary}</p>
    </div>
  </section>

  <!-- ============ the window ============ -->
  <section class="case-window on-pine">
    <div class="wrap">
      <div class="window-frame" data-reveal>
        <Cover
          id={entry.id}
          client={d.client}
          trade={d.trade}
          year={d.year}
          palette={d.palette}
          motif={d.motif}
          cover={d.cover}
          fit="cover"
        />
      </div>
    </div>
  </section>

  <!-- ============ job ticket ============ -->
  <section class="band band--tight">
    <div class="wrap">
      <dl class="ticket mono" data-reveal>
        <div class="t-cell"><dt class="tag">Client</dt><dd>{d.client}</dd></div>
        <div class="t-cell"><dt class="tag">Trade</dt><dd>{d.trade}</dd></div>
        <div class="t-cell"><dt class="tag">Place</dt><dd>{d.place}</dd></div>
        <div class="t-cell"><dt class="tag">Year</dt><dd>{d.year}</dd></div>
        <div class="t-cell t-wide"><dt class="tag">On the order</dt><dd>{d.services.join(' · ')}</dd></div>
        {d.stack.length > 0 && (
          <div class="t-cell t-wide"><dt class="tag">Runs on</dt><dd>{d.stack.join(' · ')}</dd></div>
        )}
        {d.result && (
          <div class="t-cell t-wide t-result"><dt class="tag">The takeaway</dt><dd>{d.result}</dd></div>
        )}
      </dl>

      <div class="case-cols">
        <article class="prose">
          <Content />
        </article>

        <aside class="look" aria-label="The look — palette and type">
          <p class="tag look-h">The look</p>
          <div class="swatches">
            {swatches.map((s) => (
              <div class="swatch">
                <span class="swatch-chip" style={`background:${s.hex}`}></span>
                <span class="tag swatch-role">{s.role}</span>
                <span class="mono swatch-hex">{s.hex}</span>
              </div>
            ))}
          </div>
          {d.fonts.length > 0 && (
            <p class="look-fonts">Set in <strong>{d.fonts.join(' & ')}</strong></p>
          )}
          {d.url && (
            <a class="tag look-visit" href={d.url} rel="noopener">Visit the live site <span aria-hidden="true">↗</span></a>
          )}
        </aside>
      </div>
    </div>
  </section>

  <!-- ============ next door ============ -->
  <a class="next-door on-pine" href={`/work/${next.id}/`}>
    <div class="wrap next-in">
      <span class="tag next-tag">Next door</span>
      <span class="display next-name">{next.data.client} <span class="arrow">→</span></span>
      <span class="tag next-trade">{next.data.trade} · {next.data.place}</span>
    </div>
  </a>
</Base>

<style>
  .case-head { padding-top: clamp(8rem, 16vh, 11rem); }
  .case-head .wrap { display: grid; gap: 1.6rem; justify-items: start; }
  .crumb a { text-decoration: none; color: var(--brass-2); }
  .crumb a:hover { text-decoration: underline; }
  .crumb span { opacity: 0.5; margin-inline: 0.5em; }
  .case-title { font-size: clamp(2.6rem, 1rem + 6.4vw, 6rem); }
  .case-lede { opacity: 0.92; }

  .case-window { padding-block: clamp(2.2rem, 5vw, 3.5rem) 0; }
  .window-frame {
    aspect-ratio: 21 / 10;
    border: 2.5px solid var(--bottle);
    border-bottom: 0;
    border-radius: var(--frame-r) var(--frame-r) 0 0;
    overflow: hidden;
    transform: translateY(2.5px);
  }
  .window-frame :global(.coverart) { height: 100%; }

  /* job ticket */
  .ticket {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 2px solid var(--ink);
    border-radius: 10px;
    overflow: hidden;
    background: var(--paper);
    margin-bottom: clamp(3rem, 7vw, 5.5rem);
  }
  .t-cell {
    padding: 1.05rem 1.2rem 1rem;
    border-right: 1.5px solid var(--hair-ink);
    border-bottom: 1.5px solid var(--hair-ink);
    display: grid;
    gap: 0.45rem;
    align-content: start;
  }
  .t-cell:nth-child(4n), .t-cell:last-child { border-right: 0; }
  .t-wide { grid-column: span 2; }
  .t-cell dt { color: var(--brass); }
  .t-cell dd { margin: 0; font-size: 0.92rem; line-height: 1.5; }
  .t-result dd { font-weight: 650; }

  .case-cols {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(15rem, 1fr);
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: start;
  }

  .look {
    position: sticky;
    top: 6.5rem;
    border: 2px solid var(--ink);
    border-radius: 10px;
    padding: 1.5rem;
    background: var(--paper);
    display: grid;
    gap: 1.2rem;
  }
  .look-h { color: var(--brass); }
  .swatches { display: grid; gap: 0.9rem; }
  .swatch {
    display: grid;
    grid-template-columns: 3.2rem 1fr auto;
    align-items: center;
    gap: 0.9rem;
  }
  .swatch-chip {
    height: 2.5rem;
    border-radius: 6px;
    border: 1.5px solid var(--hair-ink);
  }
  .swatch-hex { font-size: 0.78rem; opacity: 0.7; }
  .look-fonts { font-size: 0.95rem; border-top: 1.5px dashed var(--hair-ink); padding-top: 1.1rem; }
  .look-visit { text-decoration: none; border-bottom: 2px solid var(--brass); padding-bottom: 0.35em; width: fit-content; }

  /* next door */
  .next-door { display: block; text-decoration: none; }
  .next-in {
    display: grid;
    gap: 0.7rem;
    justify-items: start;
    padding-block: clamp(3rem, 7vw, 5rem);
  }
  .next-tag { color: var(--brass-2); }
  .next-name { font-size: var(--t-h2); transition: color 0.25s var(--ease-out); }
  .next-name .arrow { display: inline-block; transition: transform 0.3s var(--ease-out); }
  .next-door:hover .next-name { color: var(--brass-2); }
  .next-door:hover .next-name .arrow { transform: translateX(10px); }
  .next-trade { opacity: 0.7; }
  .next-door { border-bottom: 1.5px solid var(--hair-brass); }

  @media (max-width: 860px) {
    .ticket { grid-template-columns: repeat(2, 1fr); }
    .t-cell:nth-child(2n) { border-right: 0; }
    .case-cols { grid-template-columns: 1fr; }
    .look { position: static; }
  }
</style>
