---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorkCard from '../../components/WorkCard.astro';

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Work — Ægentes"
  description="Websites we've designed and built for shops, trades and independents — every one drawn from the business itself."
>
  <section class="band work-head">
    <div class="wrap">
      <p class="plaque plaque--brass" data-reveal>The work</p>
      <h1 class="display lines head-line">
        <span class="l"><span class="li">Every shop</span></span>
        <span class="l"><span class="li" style="--d: 110ms">on <em>the street.</em></span></span>
      </h1>
      <p class="lede" data-reveal style="--d: 240ms">
        No two trades work the same, so no two of our websites look the same.
        Each one is drawn from the business itself — its colours, its counter, its customers.
      </p>
    </div>
  </section>

  <section class="band band--tight">
    <div class="wrap">
      <div class="work-grid">
        {work.map((entry, i) => (
          <div data-reveal style={`--d: ${(i % 2) * 120}ms`}>
            <WorkCard entry={entry} headingLevel="h2" />
          </div>
        ))}
        <a class="vacant" href="/contact/" data-reveal>
          <span class="tag vacant-tag">Vacant · apply within</span>
          <span class="display vacant-line">Your name here.</span>
          <span class="tag vacant-cta">Start a project <span class="arrow">→</span></span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .work-head { padding-top: clamp(8rem, 16vh, 11rem); padding-bottom: 0; }
  .work-head .wrap { display: grid; gap: 1.8rem; justify-items: start; }
  .head-line em { color: var(--brass); }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 3.2vw, 3rem);
  }
  .work-grid > :nth-child(even) { margin-top: clamp(0rem, 5vw, 4.5rem); }

  .vacant {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    text-align: center;
    min-height: 24rem;
    border: 2.5px dashed color-mix(in srgb, var(--ink) 45%, transparent);
    border-radius: var(--frame-r);
    text-decoration: none;
    padding: 2rem;
    transition: background-color 0.3s var(--ease-out), border-color 0.3s var(--ease-out), color 0.3s var(--ease-out);
  }
  .vacant-tag { color: var(--brass); }
  .vacant-line { font-size: var(--t-h3); }
  .vacant-cta { border-bottom: 2px solid var(--brass); padding-bottom: 0.4em; }
  .vacant:hover { background: var(--pine); border-color: var(--pine); color: var(--plaster); }
  .vacant:hover .vacant-tag { color: var(--brass-2); }
  .vacant .arrow { display: inline-block; transition: transform 0.25s var(--ease-out); }
  .vacant:hover .arrow { transform: translateX(4px); }

  @media (max-width: 760px) {
    .work-grid { grid-template-columns: 1fr; }
    .work-grid > :nth-child(even) { margin-top: 0; }
    .vacant { min-height: 17rem; }
  }
</style>
