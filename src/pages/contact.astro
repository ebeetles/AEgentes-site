---
import Base from '../layouts/Base.astro';

const expectations = [
  { when: 'Within a day', what: 'A reply from a person, not an autoresponder. Usually much sooner.' },
  { when: 'Within a week', what: 'A 30-minute chat about your shop — phone or video, your pick. No slideware.' },
  { when: 'After the chat', what: 'A one-page plan with one price on it. Take it, sleep on it, or take it elsewhere — it’s yours.' },
];

const faqs = [
  {
    q: 'What does a website cost?',
    a: 'One fixed number, quoted after the first chat and itemised on the plan — design, build, words, training, the lot. If you need bookings, ordering or a shop, the number says so up front. No surprises three weeks in.',
  },
  {
    q: 'How long does it take?',
    a: 'Four weeks door-to-door for most shops and trades. Bigger builds — online ordering, subscriptions — usually run six to eight. You’ll see it growing at a private link the whole way.',
  },
  {
    q: 'Can you rescue my current site?',
    a: 'Sometimes. We’ll look for free and tell you straight: if a repair is worth it, we’ll quote the repair; if a rebuild is cheaper than a rescue, we’ll say that instead.',
  },
  {
    q: 'Do you do online ordering, bookings, gift cards?',
    a: 'Yes — it’s most of what we build. Pre-orders for bakeries, deposits for barbers, quote forms for trades, subscriptions for florists. The tools change by trade; the care doesn’t.',
  },
  {
    q: 'I’m not sure what I need.',
    a: 'Perfect — that’s what the first chat is for. Come with nothing but how your shop runs. Leave with a plan, whether or not you hire us.',
  },
];

// FAQPage schema — lets Google show these as rich results and gives
// AI answer engines a clean, quotable Q&A pair to cite directly.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title="Contact — Ægentes"
  description="Start a project with Ægentes. One email, a reply within a working day, and a one-page plan with one price on it."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="band contact-head">
    <div class="wrap">
      <p class="plaque plaque--brass" data-reveal>Contact</p>
      <h1 class="display lines head-line">
        <span class="l"><span class="li">Say <em>the word.</em></span></span>
      </h1>
      <p class="lede" data-reveal style="--d: 200ms">
        Tell us what you make, fix, bake or book — a couple of lines is plenty.
        We'll take it from there.
      </p>
      <a class="big-mail" href="mailto:hello@aegentes.com" data-reveal style="--d: 300ms">
        hello@aegentes.com
      </a>
      <p class="tag mail-note" data-reveal style="--d: 380ms">
        <span class="livedot" aria-hidden="true"></span>Open — replies within one working day
      </p>
    </div>
  </section>

  <section class="band band--tight on-pine">
    <div class="wrap">
      <header class="sect-head">
        <p class="plaque plaque--brass" data-reveal>What happens next</p>
        <h2 class="display" data-reveal style="--d: 100ms">No forms, <em>no chase.</em></h2>
      </header>
      <ol class="expect">
        {expectations.map((e, i) => (
          <li class="expect-row" data-reveal style={`--d: ${i * 90}ms`}>
            <span class="tag expect-when">{e.when}</span>
            <p class="expect-what">{e.what}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="band">
    <div class="wrap faq-wrap">
      <header class="sect-head">
        <p class="plaque plaque--brass" data-reveal>Asked across the counter</p>
        <h2 class="display" data-reveal style="--d: 100ms">Fair questions.</h2>
      </header>
      <div class="faqs" data-reveal>
        {faqs.map((f) => (
          <details class="faq">
            <summary>
              <span class="faq-q">{f.q}</span>
              <span class="faq-mark" aria-hidden="true">+</span>
            </summary>
            <p class="faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-head { padding-top: clamp(8rem, 16vh, 11rem); }
  .contact-head .wrap { display: grid; gap: 1.7rem; justify-items: start; }
  .head-line em { color: var(--brass); }

  .big-mail {
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 500;
    font-variation-settings: 'wght' 500;
    font-size: clamp(1.7rem, 1rem + 3.6vw, 3.6rem);
    line-height: 1.2;
    text-decoration-thickness: 3px;
    text-decoration-color: var(--brass);
    text-underline-offset: 0.16em;
    overflow-wrap: anywhere;
    transition: color 0.25s var(--ease-out);
  }
  .big-mail:hover { color: var(--brass); }
  .mail-note { color: var(--brass); display: inline-flex; align-items: center; gap: 0.6em; }

  .expect { list-style: none; padding: 0; display: grid; }
  .expect-row {
    display: grid;
    grid-template-columns: minmax(9rem, 14rem) 1fr;
    gap: 1rem 2.5rem;
    padding-block: 1.6rem;
    border-top: 1.5px solid var(--hair-brass);
    align-items: baseline;
  }
  .expect-row:last-child { border-bottom: 1.5px solid var(--hair-brass); }
  .expect-when { color: var(--brass-2); }
  .expect-what { max-width: 40em; opacity: 0.92; }

  .faqs { display: grid; border-top: 2px solid var(--ink); max-width: 52rem; }
  .faq { border-bottom: 2px solid var(--ink); }
  .faq summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding-block: 1.35rem;
    cursor: pointer;
    list-style: none;
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq-q {
    font-family: var(--f-display);
    font-size: clamp(1.15rem, 1rem + 0.9vw, 1.55rem);
    font-weight: 600;
    font-variation-settings: 'wght' 600;
    line-height: 1.25;
  }
  .faq-mark {
    font-family: var(--f-mono);
    font-size: 1.4rem;
    color: var(--brass);
    transition: transform 0.3s var(--ease-out);
    flex: none;
  }
  .faq[open] .faq-mark { transform: rotate(45deg); }
  .faq summary:hover .faq-q { color: var(--pine); text-decoration: underline; text-decoration-color: var(--brass); text-decoration-thickness: 2px; text-underline-offset: 0.2em; }
  .faq-a { padding-bottom: 1.5rem; max-width: 42em; opacity: 0.88; }

  @media (max-width: 640px) {
    .expect-row { grid-template-columns: 1fr; gap: 0.4rem; }
  }
</style>
